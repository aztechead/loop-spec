# feature.json is the resume contract -- commit it so resume survives clone / hand-off.
# Everything else under a feature dir (feature.json.bak, gate-logs/, transcripts) is
# per-machine churn and stays ignored.
/.loop-spec/features/*/*
!/.loop-spec/features/*/feature.json
!/.loop-spec/features/*/PROGRESS.md
/.loop-spec/worktrees/
.worktrees/
.claude/worktrees/
node_modules/
.DS_Store
*.swp
.env
.env.local
*.log

# generated by hooks/install-bundled-workflows.sh
.claude/workflows/loop-spec-*.js

# generated by tooling; never committed
docs/superpowers/
.loop-spec/learnings.jsonl
# machine-readable result pointer (lib/cycle-result.sh); local telemetry
.loop-spec/last-result.json

# loop-runner runtime state (skills/loop-runner; EXECUTE loop-fleet rung)
.loop/
*-loop-worktrees/

# python bytecode caches (loop-runner test runs)
__pycache__/
*.pyc
