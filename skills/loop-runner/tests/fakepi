#!/usr/bin/env bash
# fakepi — offline stand-in for `pi --mode json`, used by tests/run_tests.sh.
# Mirrors fakeclaude's behaviors (same env protocol) but speaks pi's event-stream
# protocol: one JSON object per line — session header first, then
# turn_start / message_end / turn_end / agent_end events.
#
# Behaviors (env-driven so one stub covers every scenario):
#   FAKE_COST     per-call usage cost           (default 1.25)
#   FAKE_STILL=1  change nothing (stall scenario)
#   FAKE_TAMPER=<path>  append to that path (verifier-integrity scenario)
#   FAKE_PLAN=<file>    return that file's contents as the result (compiler scenario)
#   FAKE_HANG=<s>       sleep (hung-tick scenario)
#   FAKE_ARGV_LOG=<f>   append full argv to <f> (flag-shape assertions)
#
# Protocol: if the prompt (any argv) contains TOUCH:<file>, create/append that file.
set -euo pipefail
COST="${FAKE_COST:-1.25}"

if [[ -n "${FAKE_ARGV_LOG:-}" ]]; then
  printf '%s\n' "$*" >> "$FAKE_ARGV_LOG"
fi

if [[ -n "${FAKE_HANG:-}" ]]; then
  sleep "$FAKE_HANG"
fi

PROMPT=""
for a in "$@"; do PROMPT="$PROMPT $a"; done

emit() { # emit <result-text> <cost>
  python3 - "$1" "$2" << 'EOF'
import json, sys
text, cost = sys.argv[1], float(sys.argv[2])
# Shapes per pi's session-format docs: header {"type":"session","id":...};
# assistant usage.cost is an OBJECT {input, output, cacheRead, cacheWrite, total}.
print(json.dumps({"type": "session", "version": 3, "id": "pisess-abc",
                  "timestamp": "2026-01-01T00:00:00.000Z", "cwd": "/tmp"}))
print(json.dumps({"type": "turn_start"}))
print(json.dumps({"type": "message_end", "message": {
    "role": "assistant",
    "content": [{"type": "text", "text": text}],
    "usage": {"input": 10, "output": 5, "cacheRead": 0, "cacheWrite": 0,
              "totalTokens": 15,
              "cost": {"input": 0.0, "output": cost, "cacheRead": 0.0,
                       "cacheWrite": 0.0, "total": cost}}}}))
print(json.dumps({"type": "turn_end"}))
print(json.dumps({"type": "agent_end"}))
EOF
}

if [[ -n "${FAKE_PLAN:-}" ]]; then
  emit "$(cat "$FAKE_PLAN")" "$COST"
  exit 0
fi

if [[ -n "${FAKE_TAMPER:-}" ]]; then
  echo "tampered" >> "$FAKE_TAMPER"
fi

if [[ "$PROMPT" =~ TOUCH:([A-Za-z0-9._/-]+) ]]; then
  f="${BASH_REMATCH[1]}"
  mkdir -p "$(dirname "$f")" 2>/dev/null || true
  echo "work $(date +%s%N)" >> "$f"
elif [[ "${FAKE_STILL:-0}" != "1" ]]; then
  echo "iter $(date +%s%N)" >> work.txt
fi

emit "did some work this iteration" "$COST"
